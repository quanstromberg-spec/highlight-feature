{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "paths": {
      "@husqvarna/ui-core/*": ["./vendor/ui-core/*"],
      "@husqvarna/ui-core": ["./vendor/ui-core"]
    }
  },
  "include": ["src"]
}
